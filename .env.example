# Microsoft Fabric / Power BI Authentication
# Option 1: Service Principal (recommended for automation)
FABRIC_TENANT_ID=your-tenant-id
FABRIC_CLIENT_ID=your-client-id
FABRIC_CLIENT_SECRET=your-client-secret

# Option 2: Azure CLI (for interactive use)
# Leave the above blank and ensure `az login` has been run.

# Default workspace (optional -- tools accept workspace_id as parameter)
FABRIC_DEFAULT_WORKSPACE_ID=your-default-workspace-id
